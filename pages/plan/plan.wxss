/* ===== 全局 ===== */
page {
  background: #FFF9F0;
  font-size: 28rpx;
  color: #4A1515;
  height: 100vh;
  overflow: hidden;
}
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 加载动画：共用 app.wxss 中的 .loading-mask / .pattern-spinner ===== */
.loading-mask {
  background-color: #FFF9F0;
  z-index: 9999;
}

/* ===== 主内容区 ===== */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 顶部操作栏（剪纸风格） ===== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(180deg, rgba(200,16,46,0.04), rgba(255,249,240,0.96));
  border-bottom: 2rpx solid #D4AF37;
  border-image: repeating-linear-gradient(
    90deg,
    #D4AF37 0, #D4AF37 12rpx,
    transparent 12rpx, transparent 16rpx,
    #C8102E 16rpx, #C8102E 20rpx,
    transparent 20rpx, transparent 24rpx
  ) 2;
  box-shadow: 0 2rpx 10rpx rgba(160,60,20,0.08);
  flex-shrink: 0;
  z-index: 10;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #C8102E;
  text-shadow: 0 1rpx 0 rgba(212,175,55,0.3);
}
.new-session-btn {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #C8102E, #A01026);
  border: 2rpx solid #D4AF37;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3rpx 10rpx rgba(200,16,46,0.3), inset 0 0 12rpx rgba(255,200,100,0.1);
  transition: all 0.15s ease;
}
.new-session-btn:active {
  transform: scale(0.92);
  opacity: 0.85;
}
.btn-text {
  color: #fff;
  font-size: 30rpx;
}

/* ============================================ */
/*  聊天区域（剪纸非遗风格）                       */
/* ============================================ */
.chat-wrapper {
  flex: 1;
  height: 0;
  position: relative;
}
.chat-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}
/* 宣纸肌理遮罩层（纯CSS，轻量） */
.paper-grain-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 30% 20%, rgba(200,16,46,0.02) 1rpx, transparent 1rpx),
    radial-gradient(circle at 70% 60%, rgba(212,175,55,0.03) 1rpx, transparent 1rpx),
    radial-gradient(circle at 50% 80%, rgba(200,16,46,0.015) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx, 100rpx 100rpx, 120rpx 120rpx;
  opacity: 0.8;
}
.chat-box {
  position: relative;
  z-index: 2;
  height: 100%;
  padding: 20rpx;
}

/* 消息布局 */
.user-msg,
.ai-msg {
  display: flex;
  margin: 18rpx 0;
  max-width: 82%;
}
.user-msg {
  flex-direction: row-reverse;
  margin-left: auto;
}

/* 头像 */
.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #fff;
  text-align: center;
  line-height: 56rpx;
  margin: 4rpx 8rpx 0;
  flex-shrink: 0;
  font-size: 26rpx;
}
.ai-msg .avatar {
  background: #C8102E;
  border: 2rpx solid #D4AF37;
}
.user-msg .avatar {
  background: #C8102E;
  border: 2rpx solid #FFD700;
}

/* ===== 气泡基础 ===== */
.content {
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  line-height: 1.7;
  font-size: 28rpx;
  position: relative;
}

/* ============================================ */
/*  AI 气泡：宣纸白 + 朱红描边 + 描金（剪纸风）    */
/* ============================================ */
.ai-bubble {
  background-color: #FFF9F0;
  color: #4A1515;
  border: 3rpx solid #C8102E;
  border-radius: 18rpx 18rpx 18rpx 6rpx;
  box-shadow:
    inset 0 0 0 2rpx #FFF,
    inset 0 0 16rpx rgba(200,16,46,0.08),
    0 4rpx 16rpx rgba(160,60,20,0.15),
    0 2rpx 0 rgba(200,16,46,0.1);
}
/* 描金内线 */
.ai-bubble::before {
  content: "";
  position: absolute;
  top: 5rpx; left: 5rpx;
  right: 5rpx; bottom: 5rpx;
  border: 1rpx solid rgba(212,175,55,0.5);
  border-radius: 15rpx 15rpx 15rpx 3rpx;
  pointer-events: none;
  z-index: 0;
}
/* 左下剪纸衔接角 */
.ai-bubble::after {
  content: "";
  position: absolute;
  left: -9rpx;
  bottom: 2rpx;
  width: 16rpx;
  height: 16rpx;
  background: #D4AF37;
  border-radius: 2rpx;
  transform: rotate(45deg);
  box-shadow: 0 0 6rpx rgba(200,16,46,0.4);
  z-index: -1;
}

/* ============================================ */
/*  用户气泡：朱砂红 + 描金（剪纸风）              */
/* ============================================ */
.user-bubble {
  background: linear-gradient(160deg, #D42020, #B01010);
  color: #FFF;
  border: 3rpx solid #D4AF37;
  border-radius: 18rpx 18rpx 6rpx 18rpx;
  box-shadow:
    inset 0 0 0 2rpx rgba(255,255,255,0.15),
    inset 0 0 20rpx rgba(255,200,100,0.08),
    0 4rpx 16rpx rgba(180,20,20,0.25),
    0 2rpx 0 rgba(212,175,55,0.2);
}
/* 描金内线 */
.user-bubble::before {
  content: "";
  position: absolute;
  top: 5rpx; left: 5rpx;
  right: 5rpx; bottom: 5rpx;
  border: 1rpx solid rgba(255,215,0,0.5);
  border-radius: 15rpx 15rpx 3rpx 15rpx;
  pointer-events: none;
  z-index: 0;
}
/* 右下剪纸衔接角 */
.user-bubble::after {
  content: "";
  position: absolute;
  right: -9rpx;
  bottom: 2rpx;
  width: 16rpx;
  height: 16rpx;
  background: #D4AF37;
  border-radius: 2rpx;
  transform: rotate(45deg);
  box-shadow: 0 0 6rpx rgba(200,16,46,0.4);
  z-index: -1;
}

/* ===== 底部输入栏（剪纸风格） ===== */
.input-bar {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background: linear-gradient(180deg, #FFF9F0, #FFFDF8);
  border-top: 2rpx solid #D4AF37;
  box-shadow: 0 -3rpx 14rpx rgba(160,60,20,0.1);
  flex-shrink: 0;
  z-index: 10;
}
.input {
  flex: 1;
  height: 70rpx;
  background: #FFF9F0;
  border-radius: 35rpx;
  padding: 0 25rpx;
  margin-right: 15rpx;
  border: 2rpx solid #C8102E;
  font-size: 28rpx;
  color: #4A1515;
  box-shadow: inset 0 2rpx 8rpx rgba(200,16,46,0.06);
  transition: all 0.2s ease;
}
.input:focus {
  border-color: #D4AF37;
  box-shadow: inset 0 2rpx 8rpx rgba(200,16,46,0.1), 0 0 12rpx rgba(212,175,55,0.2);
}
.send-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8102E, #A01026);
  border: 2rpx solid #D4AF37;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(200,16,46,0.35), inset 0 0 12rpx rgba(255,200,100,0.12);
  transition: all 0.15s ease;
}
.send-btn:active {
  transform: scale(0.9);
  opacity: 0.85;
}
.paper-plane {
  color: #FFF;
  font-size: 32rpx;
}