/* 全屏背景图 */
.bg-img {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  object-fit: cover;
  z-index: -1;
}

/* 功能卡片容器 */
.card-container {
  width: 100%;
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 600rpx; /* 调整此值让卡片落在背景图的黑色区域 */
  box-sizing: border-box;
}

/* 功能卡片样式 */
.func-card {
  width: 100%;
  height: auto;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
  transition: transform 0.2s;
}

/* 卡片点击反馈 */
.func-card:active {
  transform: scale(0.98);
}