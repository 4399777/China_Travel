<view class="container">
  <view class="title-primary">个人中心</view>
  <!-- 用户信息展示 -->
  <view style="display: flex; align-items: center; justify-content: center; margin: 50rpx 0;">
    <image src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" style="width: 160rpx; height: 160rpx; border-radius: 80rpx;" mode="widthFix"></image>
    <view style="margin-left: 30rpx;">
      <view style="font-size: 36rpx; font-weight: 600;">{{userInfo.nickName || '外籍游客'}}</view>
      <view style="font-size: 28rpx; color: #666; margin-top: 10rpx;">非遗文旅体验官</view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view style="background: #FFFFFF; border-radius: 20rpx; padding: 20rpx 0; margin: 30rpx 0;">
    <view style="display: flex; align-items: center; justify-content: space-around; padding: 30rpx 0; border-bottom: 2rpx solid #F0E6D2;">
      <view bindtap="toHistory" style="text-align: center;">
        <view style="font-size: 80rpx; color: #C8102E;">📜</view>
        <view style="font-size: 32rpx; margin-top: 10rpx;">我的规划</view>
      </view>
      <view bindtap="toHistory" style="text-align: center;">
        <view style="font-size: 80rpx; color: #C8102E;">🎬</view>
        <view style="font-size: 32rpx; margin-top: 10rpx;">我的体验</view>
      </view>
    </view>
    <view bindtap="toAbout" style="text-align: center; padding: 30rpx 0; font-size: 32rpx; color: #666;">
      关于非遗文旅AI助手
    </view>
  </view>

  <!-- 历史记录（答辩演示用，假数据） -->
  <view class="title-secondary">最近体验</view>
  <view class="result-box" style="margin: 10rpx 0;">
    <view style="font-weight: 600;">傣族打招呼方式体验</view>
    <view style="font-size: 28rpx; color: #666; margin-top: 10rpx;">2026-02-03 15:30</view>
  </view>
  <view class="result-box" style="margin: 10rpx 0;">
    <view style="font-weight: 600;">云南3天非遗扎染旅游规划</view>
    <view style="font-size: 28rpx; color: #666; margin-top: 10rpx;">2026-02-02 10:15</view>
  </view>
</view>